# ── The Nail Hubs — environment variables ────────────────────────────
# Copy to .env.local for local dev, or add in Vercel → Project → Settings
# → Environment Variables. Everything degrades gracefully when missing.

# ── Supabase (the booking database — free tier, takes 5 minutes) ─────
# 1. Create a free project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL Editor (one paste, one click)
# 3. Project Settings → API: copy the URL and the service_role key
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: live Instagram feed & stories ──────────────────────────
# Without this, the site shows the official Instagram profile embed
# (which needs no key at all). Add later if you ever want native posts.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=me

# ── Optional: live Google rating & reviews ───────────────────────────
# Without these, the site shows curated 5-star testimonials.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
